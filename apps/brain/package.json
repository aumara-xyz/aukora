{
  "name": "@aukora/brain",
  "version": "0.1.0",
  "private": true,
  "description": "The Aukora organism brain: a reactive, receipt-chained, growing memory store (Convex-backed adapter) built on the pure @aukora/memory and @aukora/kernel contracts. Adapter, not a portable package.",
  "author": "Aumara",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@aukora/kernel": "0.1.0",
    "@aukora/evidence": "0.1.0",
    "@aukora/memory": "0.1.0",
    "@noble/hashes": "2.2.0"
  },
  "devDependencies": {
    "convex": "1.42.2",
    "convex-test": "0.0.54"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "verify": "tsc -p tsconfig.json && vitest run --config vitest.config.ts",
    "dev:local": "convex dev",
    "local:up": "convex dev --once --codegen disable --typecheck disable",
    "local:hold": "convex dev --tail-logs disable --codegen disable --typecheck disable",
    "local:health": "convex run memory:health",
    "local:down": "pkill -f convex-local-backend || true",
    "compose:live": "AUKORA_LIVE_COMPOSE=1 vitest run --config vitest.config.ts test/live.compose.test.ts"
  }
}
